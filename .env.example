# ── MongoDB Atlas connection ─────────────────────────────
# Copy this file to ".env" and fill in your own credentials.
# NEVER commit the real .env file (it is git-ignored).
#
# Format:
#   mongodb+srv://<user>:<password>@<cluster-host>/?appName=<app>
#
# If your password contains special characters (@ : / # ? & %),
# URL-encode them — e.g. "#" -> "%23", "@" -> "%40".
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.example.mongodb.net/?appName=Cluster0
